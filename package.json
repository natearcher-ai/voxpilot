{
  "name": "voxpilot",
  "displayName": "VoxPilot — Voice to Code",
  "description": "Talk to your IDE coding assistant. On-device voice transcription powered by Moonshine ASR. No API keys, no cloud, just your voice.",
  "version": "0.4.4",
  "publisher": "natearcher-ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/natearcher-ai/voxpilot"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Chat"
  ],
  "keywords": [
    "voice",
    "speech",
    "transcription",
    "copilot",
    "assistant",
    "hands-free",
    "accessibility",
    "moonshine",
    "asr"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "voxpilot.toggleListening",
        "title": "VoxPilot: Toggle Voice Input",
        "icon": "$(mic)"
      },
      {
        "command": "voxpilot.pushToTalk",
        "title": "VoxPilot: Quick Voice Capture (Toggle)"
      },
      {
        "command": "voxpilot.selectModel",
        "title": "VoxPilot: Select ASR Model"
      },
      {
        "command": "voxpilot.selectAudioDevice",
        "title": "VoxPilot: Select Audio Input Device"
      },
      {
        "command": "voxpilot.transcriptHistory",
        "title": "VoxPilot: Transcript History"
      },
      {
        "command": "voxpilot.inlineVoiceInput",
        "title": "VoxPilot: Inline Voice Input (Insert at Cursor)"
      },
      {
        "command": "voxpilot.sendToChat",
        "title": "VoxPilot: Send Last Transcript to Chat"
      },
      {
        "command": "voxpilot.clearCache",
        "title": "VoxPilot: Clear Cache"
      }
    ],
    "keybindings": [
      {
        "command": "voxpilot.toggleListening",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v"
      },
      {
        "command": "voxpilot.pushToTalk",
        "key": "ctrl+alt+q",
        "mac": "cmd+alt+q"
      },
      {
        "command": "voxpilot.inlineVoiceInput",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "VoxPilot",
      "properties": {
        "voxpilot.model": {
          "type": "string",
          "default": "moonshine-base",
          "enum": [
            "moonshine-tiny",
            "moonshine-base"
          ],
          "description": "ASR model to use. Tiny (~26MB) is faster, Base (~60MB) is more accurate."
        },
        "voxpilot.vadSensitivity": {
          "type": "number",
          "default": 0.5,
          "minimum": 0.1,
          "maximum": 0.95,
          "description": "Voice activity detection threshold. Lower = more sensitive."
        },
        "voxpilot.autoSendToChat": {
          "type": "boolean",
          "default": false,
          "description": "Automatically send completed transcripts to the active chat participant."
        },
        "voxpilot.targetChatParticipant": {
          "type": "string",
          "default": "",
          "description": "Chat participant ID to send voice input to (e.g. 'github.copilot'). Leave empty for default."
        },
        "voxpilot.silenceTimeout": {
          "type": "number",
          "default": 1500,
          "description": "Milliseconds of silence before finalizing a transcript segment."
        },
        "voxpilot.maxSpeechDuration": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 60,
          "description": "Maximum speech duration in seconds before auto-transcribing. Moonshine works best under 15s; increase for longer dictation at the cost of accuracy."
        },
        "voxpilot.audioDevice": {
          "type": "string",
          "default": "",
          "description": "Audio input device ID. Leave empty for system default. Use 'VoxPilot: Select Audio Input Device' to pick one."
        },
        "voxpilot.soundFeedback": {
          "type": "boolean",
          "default": true,
          "description": "Play subtle beep sounds when voice input starts and stops."
        },
        "voxpilot.inlineMode": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, transcripts are inserted directly at the cursor position instead of being sent to chat. Toggle per-session with 'VoxPilot: Inline Voice Input'."
        },
        "voxpilot.noiseGateThreshold": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 0.1,
          "description": "Noise gate RMS threshold (0–0.1). Audio frames below this level are silenced before reaching VAD. 0 = disabled. Try 0.005–0.02 to filter fan/hum noise."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:onnxruntime-node --external:@huggingface/transformers --format=cjs --platform=node --target=node18",
    "watch": "npm run build -- --watch --sourcemap",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {},
  "optionalDependencies": {
    "onnxruntime-node": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0"
  }
}
